    async function initApp() {
        try {
            const response = await fetch('data.json');
            if (response.ok) {
                data = await response.json();
            } else {
                data = fallbackData;
            }
        } catch (error) {
            data = fallbackData; 
        }
        boot(); 
    }

    function closeIntro() {
        const intro = document.getElementById('introPage');
        if (intro) intro.classList.add('hidden');
        
        const vidPlayer = document.getElementById('introVideo');
        if (vidPlayer) {
            vidPlayer.muted = true;
            vidPlayer.pause();
        }
        const resetBtn = document.getElementById('btnReset');
        if (resetBtn) resetBtn.style.display = '';
    }

    function resetApp() {
        closeSelection(); 
        const searchBox = document.getElementById('searchBox');
        if (searchBox) searchBox.value = '';
        currentCategory = 'all';
        renderCategoryChips();
        handleSearch(); 
        
        toggleMapExpand(false);

        const intro = document.getElementById('introPage');
        if (intro) intro.classList.remove('hidden');
        
        const resetBtn = document.getElementById('btnReset');
        if (resetBtn) resetBtn.style.display = 'none';
        
        const vidPlayer = document.getElementById('introVideo');
        if (vidPlayer) {
            vidPlayer.play().catch(e => console.warn("Video play prevented:", e));
        }
    }

    function setLang(lang) {
        if (!i18n[lang]) lang = 'nl'; // Safety fallback
        curLang = lang;
        localStorage.setItem('bouwmaat_lang', lang);
        
        document.querySelectorAll('.flag-btn').forEach(btn => btn.classList.remove('active'));
        const activeBtn = document.getElementById(`btn-${lang}`);
        if(activeBtn) activeBtn.classList.add('active');
        
        document.querySelectorAll('.intro-lang-toggles').forEach(btn => btn.classList.remove('active'));
        const activeIntroBtn = document.getElementById(`intro-btn-${lang}`);
        if(activeIntroBtn) activeIntroBtn.classList.add('active');
        
        const t = i18n[lang];
        
        const elIntroTitle = document.getElementById('introTitle');
        if(elIntroTitle) elIntroTitle.innerHTML = t.introTitle;
        const elIntroSlogan = document.getElementById('introSlogan');
        if(elIntroSlogan) elIntroSlogan.innerText = t.introSlogan;
        const elIntroNavTitle = document.getElementById('introNavTitle');
        if(elIntroNavTitle) elIntroNavTitle.innerText = t.introNav;
        const elIntroText = document.getElementById('introText');
        if(elIntroText) elIntroText.innerText = t.introP;
        const elIntroBtnText = document.getElementById('introBtnText');
        if(elIntroBtnText) elIntroBtnText.innerText = t.introBtn;
        
        const elSearchBox = document.getElementById('searchBox');
        if(elSearchBox) elSearchBox.placeholder = t.placeholder;
        const elBtnReset = document.getElementById('btnReset');
        if(elBtnReset) elBtnReset.innerText = t.reset;
        const elBtnSearch = document.getElementById('btnSearch');
        if(elBtnSearch) elBtnSearch.innerHTML = window.innerWidth < 400 ? "🔍" : t.search;
        
        document.documentElement.style.setProperty('--txt-entrance', `"${t.entrance}"`);
        const lblService = document.getElementById('label-service');
        if(lblService) lblService.innerText = t.serviceDesk;
        const lblSales1 = document.getElementById('label-sales1');
        if(lblSales1) lblSales1.innerText = t.salesDesk;
        const lblKassa = document.getElementById('label-kassa');
        if(lblKassa) lblKassa.innerText = t.kassa;
        const lblCoffee = document.getElementById('label-coffee');
        if(lblCoffee) lblCoffee.innerText = t.coffeeCorner;
        const lblPaint = document.getElementById('label-paint');
        if(lblPaint) lblPaint.innerText = t.paintDesk;
        const lblSpell = document.getElementById('spellCheckPrefix');
        if(lblSpell) lblSpell.innerText = t.didYouMean;
        
        // Update map labels with new translations
        document.querySelectorAll('.cat-label').forEach(el => {
            const cat = el.dataset.cat;
            el.innerText = (t.groups && t.groups[cat]) ? t.groups[cat].toUpperCase() : cat.toUpperCase();
        });
        document.querySelectorAll('.back-label').forEach(el => {
            const backId = el.dataset.back;
            el.innerText = (t.backLabels && t.backLabels[backId]) ? t.backLabels[backId].toUpperCase() : (backAisleLabels[backId] || "").toUpperCase();
        });
        const elFooterRights = document.getElementById('footerRights');
        if (elFooterRights) elFooterRights.innerText = t.rightsReserved;
        
        // Update special locations translations
        const awLoc = specialLocations.find(s => s.id === '0AW');
        if (awLoc) {
            awLoc.short = t.backWallShort;
            awLoc.long = t.backWallLong;
        }
        
        // Dynamic Video Switching per Language
        const videoSrcs = {
            nl: "dutch1.mp4",
            en: "eng.mp4",
            uk: "uk1.mp4",
            pl: "pol1.mp4"
        };
        const vidPlayer = document.getElementById('introVideo');
        if (vidPlayer) {
            if (vidPlayer.getAttribute('src') !== videoSrcs[lang]) {
                vidPlayer.src = videoSrcs[lang];
                vidPlayer.load();
                vidPlayer.play().catch(e => console.warn("Auto-play prevented:", e));
            }
        }
        
        renderCategoryChips();
        handleSearch();
    }

    function renderCategoryChips() {
        const t = i18n[curLang];
        const container = document.getElementById('categoryChips');
        if (!container || !data) return;
        container.innerHTML = '';
        const allChip = document.createElement('div');
        allChip.className = `category-chip ${currentCategory === 'all' ? 'active' : ''}`;
        allChip.textContent = t.allCats;
        allChip.onclick = () => selectCategory('all');
        container.appendChild(allChip);

        const allCategories = [
            "Bouwmaterialen", "Hout", "Gereedschap", "Bevestigingsmateriaal", "Verf", 
            "Sanitair", "Elektra", "Verwarming en klimaat", "Lijm, kit en pur",
            "Verlichting", "Hang- en sluitwerk", 
            "Keukens", "Persoonlijke beschermings", "Eigen gebruik"
        ];
        
        const hiddenCategories = [
            "IJzerwaren", "Bouwstoffen", "Verwarming", "Deuren & Kozijnen", 
            "Kleding & schoenen", "Emballage", "Lokaal", "Algemeen",
            "Schoonmaak, bedrijfswagen", "Schoonmaak bedrijfswagen"
        ];
        
        const dataCats = [...new Set(data.map(item => item["Hoofdgroep"]))];
        const combinedCats = [...new Set([...allCategories, ...dataCats])].filter(cat => !hiddenCategories.includes(cat));

        combinedCats.forEach(cat => {
            if (!cat) return;
            const chip = document.createElement('div');
            chip.className = `category-chip ${currentCategory === cat ? 'active' : ''}`;
            const transCat = (t.groups && t.groups[cat]) ? t.groups[cat] : cat;
            chip.innerHTML = `${icons[cat] || '📦'} ${transCat}`;
            chip.onclick = () => selectCategory(cat);
            container.appendChild(chip);
        });
    }

    function selectCategory(cat) {
        const container = document.getElementById('categoryChips');
        const currentScroll = container ? container.scrollLeft : 0; 
        
        currentCategory = cat;
        renderCategoryChips();
        handleSearch();
        
        if (document.getElementById('categoryChips')) {
            document.getElementById('categoryChips').scrollLeft = currentScroll;
        }
    }

    function boot() {
        window.dictSet = new Set();
        data.forEach(item => {
            if(!item._searchStr) {
                const fullText = `${item["ArtikelNr."] || ''} ${item["Schaplocatie code"] || ''} ${item["Artikel omsch."] || ''} ${item["Hoofdgroep"] || ''} ${item["Subgroep"] || ''}`;
                item._searchStr = normalizeStr(fullText);
                item._cleanArt = (item["ArtikelNr."] || '').toString().replace(/[-\s]/g, '').toLowerCase();
                item._nameNorm = normalizeStr(item["Artikel omsch."] || '');
                item._nameWords = item._nameNorm.split(/\s+/).filter(w => w.length > 0);
            }
            item._nameWords.forEach(w => {
                let cw = w.replace(/[^a-z0-9]/g, '');
                if (cw.length >= 2) window.dictSet.add(cw); // Verzamelt nu ook kortere woorden/getallen voor suggesties
            });
        });
        window.dictArray = Array.from(window.dictSet);

        const grid = document.getElementById('mapGrid'), svg = document.getElementById('pathLayer'), char = document.getElementById('mainChar');
        const cashiers = document.getElementById('cashierZone'), coffee = document.getElementById('coffeeCorner');
        const backWall = document.getElementById('p-0AW');
        if(svg) svg.remove(); 
        if(char) char.remove(); 
        if(cashiers) cashiers.remove(); 
        if(coffee) coffee.remove(); 
        if(backWall) backWall.remove();
        
        if (!grid) return; 

        // Generate Section Numbers
        let bottomSecs = ''; for(let s=1; s<=6; s++) bottomSecs += `<span>${s}</span>`;
        let topSecs = ''; for(let s=7; s<=17; s++) topSecs += `<span>${s}</span>`;
        
        // Solid wall stretches (1 through 17)
        let allSecs = ''; for(let s=1; s<=17; s++) allSecs += `<span>${s}</span>`;

        // Left Boundary Wall (Aisle 1 Left - Stretches all the way to entrance wall)
        const lw = document.createElement('div');
        lw.className = 'aisle left-wall-aisle';
        lw.id = 'p-1L';
        lw.style.marginBottom = '-75px'; // Extends the wall down into the entrance padding
        lw.innerHTML = `
            <div class="aisle-part" style="flex: 1;" onclick="event.stopPropagation(); handleMapClick(event, '1L', 'full')">
                <div class="left-face"></div>
                <div class="aisle-category-label cat-label label-left" data-cat="Hout">HOUT</div>
                <div class="sec-container">${allSecs}</div>
            </div>
            <div class="aisle-num" id="badge-1L">1L</div>
        `;
        grid.appendChild(lw);

        for (let i = 1; i <= 17; i++) {
            const div = document.createElement('div');
            div.className = 'aisle' + (i === 17 ? ' right-wall-aisle' : ''); 
            div.id = `p-${i}`; div.dataset.num = i;
            
            let colorClass = '';
            if (i >= 3 && i <= 13) {
                colorClass = 'front-orange';
            }
            
            let catLabelTop = '';
            let catLabelBottom = '';

            if (i === 17) {
                catLabelTop = backAisleLabels[i] ? `<div class="aisle-category-label back-label label-left" data-back="${i}">${backAisleLabels[i]}</div>` : '';
                catLabelBottom = aisleCategories[i] ? `<div class="aisle-category-label cat-label label-left" data-cat="${aisleCategories[i]}">${aisleCategories[i]}</div>` : '';
            } else {
                catLabelTop = backAisleLabels[i] ? `
                    <div class="aisle-category-label back-label label-left" data-back="${i}">${backAisleLabels[i]}</div>
                    <div class="aisle-category-label back-label label-right" data-back="${i}">${backAisleLabels[i]}</div>
                ` : '';
                catLabelBottom = aisleCategories[i] ? `
                    <div class="aisle-category-label cat-label label-left" data-cat="${aisleCategories[i]}">${aisleCategories[i]}</div>
                    <div class="aisle-category-label cat-label label-right" data-cat="${aisleCategories[i]}">${aisleCategories[i]}</div>
                ` : '';
            }
            
            if (i === 9) {
                div.innerHTML = `
                    <div class="aisle-part top" onclick="event.stopPropagation(); handleMapClick(event, '${i}', 'top')">
                        <div class="left-face"></div>
                        ${catLabelTop}
                        <div class="sec-container">${topSecs}</div>
                    </div>
                    <div class="aisle-part bottom ${colorClass}" onclick="event.stopPropagation(); handleMapClick(event, '${i}', 'bottom')">
                        <div class="left-face"></div>
                        ${catLabelBottom}
                        <div class="sec-container">${bottomSecs}</div>
                    </div>
                    <div class="paint-table" onclick="event.stopPropagation(); handleMapClick(event, '${i}', 'paint')">
                        <div class="desk-label toggle-label" id="label-paint" style="top: 100%; left: 50%;">Verfbalie</div>
                    </div>
                    <div class="aisle-num">${i}</div>
                `;
            } else if (i === 17) {
                // Aisle 17 is one continuous block on the right wall
                div.innerHTML = `
                    <div class="aisle-part" style="flex: 1;" onclick="event.stopPropagation(); handleMapClick(event, '${i}', 'full')">
                        <div class="left-face"></div>
                        ${catLabelBottom}
                        <div class="sec-container">${allSecs}</div>
                    </div>
                    <div class="aisle-num">${i}</div>
                `;
            } else {
                // All standard aisles split into top and bottom
                div.innerHTML = `
                    <div class="aisle-part top" onclick="event.stopPropagation(); handleMapClick(event, '${i}', 'top')">
                        <div class="left-face"></div>
                        ${catLabelTop}
                        <div class="sec-container">${topSecs}</div>
                    </div>
                    <div class="aisle-part bottom ${colorClass}" onclick="event.stopPropagation(); handleMapClick(event, '${i}', 'bottom')">
                        <div class="left-face"></div>
                        ${catLabelBottom}
                        <div class="sec-container">${bottomSecs}</div>
                    </div>
                    <div class="aisle-num">${i}</div>
                `;
            }
            grid.appendChild(div);
        }

        const entLabel = document.createElement('div');
        entLabel.className = 'entrance-label'; entLabel.id = 'entranceText';

        if (backWall) {
            // Horizontal shelf positions along the back wall
            let bwSecs = '';
            for(let s=1; s<=17; s++) {
                bwSecs += `<span data-sec="${s}" style="transform: rotateX(-55deg) translateZ(30px) translateY(32px); font-size: 0.6rem; padding: 3px 6px; z-index: 50;">${s}</span>`;
            }
            backWall.innerHTML = `<div class="sec-container" style="flex-direction: row; width: 100%; height: 100%; justify-content: space-evenly; align-items: center; padding: 0 10px;">${bwSecs}</div>`;
            grid.appendChild(backWall);
        }
        
        if (cashiers) grid.appendChild(cashiers);
        if (coffee) grid.appendChild(coffee);
        if (svg) grid.appendChild(svg);
        grid.appendChild(entLabel);
        if (char) grid.appendChild(char);
        
        const dimBtn = document.getElementById('btnDimToggle');
        if(dimBtn) dimBtn.innerText = document.body.classList.contains('dark-mode') ? '☀️' : '🌙';
        
        setLang(curLang); 
        
        setTimeout(() => {
            const aisle5 = document.getElementById('p-5');
            const aisle6 = document.getElementById('p-6');
            let entranceX = 270;
            if (aisle5 && aisle6) {
                entranceX = aisle5.offsetLeft + aisle5.offsetWidth + (aisle6.offsetLeft - (aisle5.offsetLeft + aisle5.offsetWidth)) / 2;
            } else {
                const centerAisle = document.getElementById('p-9');
                entranceX = centerAisle ? centerAisle.offsetLeft - 11 : 270;
            }
            window.entrancePosX = entranceX;
            // 18px spacing to the left of the character to avoid overlap
            entLabel.style.left = `calc(${entranceX}px - 18px)`; 
            entLabel.style.bottom = `0%`;
            entLabel.onclick = closeSelection;
            moveChar('entrance', false, false, null, null);
        }, 50); 
        
        const elSearchBox = document.getElementById('searchBox');
        if(elSearchBox) {
            elSearchBox.addEventListener('input', handleSearch);
            elSearchBox.addEventListener('keydown', handleKeys);
        }
        window.addEventListener('resize', () => setLang(curLang));
    }

    function toggleDimMode() {
        document.body.classList.toggle('dark-mode');
        const dimBtn = document.getElementById('btnDimToggle');
        if(dimBtn) dimBtn.innerText = document.body.classList.contains('dark-mode') ? '☀️' : '🌙';
    }

    function levenshteinDistance(a, b) {
        if (!a || !b) return (a || b).length;
        const matrix = Array(b.length + 1).fill(null).map(() => Array(a.length + 1).fill(null));
        for (let i = 0; i <= a.length; i += 1) matrix[0][i] = i;
        for (let j = 0; j <= b.length; j += 1) matrix[j][0] = j;
        for (let j = 1; j <= b.length; j += 1) {
            for (let i = 1; i <= a.length; i += 1) {
                const indicator = a[i - 1] === b[j - 1] ? 0 : 1;
                matrix[j][i] = Math.min(matrix[j][i - 1] + 1, matrix[j - 1][i] + 1, matrix[j - 1][i - 1] + indicator);
            }
        }
        return matrix[b.length][a.length];
    }

    function normalizeStr(str) {
        return str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[-]/g, ' ');
    }

    let popupTimer;
    function showAislePopup(num) {
        if(num === 'SPECIAL' || num === 'entrance') return;
        if(num === 'KAS' || num === 'KOFFIE' || num === 'paint') return; // Redundant popup suppressed since 3D labels handle it beautifully
        const popup = document.getElementById('aislePopup');
        if(!popup) return;
        let targetEl, popupText = "";
        const t = i18n[curLang] || i18n['nl'];
        
        if (num === '0AW') { targetEl = document.getElementById('p-0AW'); popupText = t.backWallShort; }
        else if (!isNaN(num) || num === '1L') {
            targetEl = document.getElementById(`p-${num}`);
            const displayNum = num === '1L' ? '1' : num;
            const translatedCat = (t.groups && t.groups[aisleCategories[displayNum]]) ? t.groups[aisleCategories[displayNum]] : (aisleCategories[displayNum] || "Algemeen");
            popupText = `${t.pad} ${num}: ${translatedCat}`;
        }
        
        if(!targetEl) return;
        const rect = targetEl.getBoundingClientRect();
        popup.style.left = `${rect.left + (rect.width / 2)}px`;
        popup.style.top = `${rect.top - 10}px`;
        popup.innerHTML = popupText;
        popup.classList.add('show');
        clearTimeout(popupTimer);
        popupTimer = setTimeout(() => { popup.classList.remove('show'); }, 2500);
    }

    function handleMapClick(e, id, part) {
        const wrapper = document.getElementById('mapWrapper');
        const isExpanded = wrapper.classList.contains('map-expanded-overlay');
        
        const originalPart = part;
        // On the first (compact) map, do not divide the aisle section when clicked
        if (!isExpanded && (part === 'top' || part === 'bottom')) {
            part = 'full';
        }

        document.querySelectorAll('.aisle, .back-wall, .result-item, .paint-table').forEach(x => {
            x.classList.remove('active', 'active-top', 'active-bottom', 'active-num', 'selected', 'active-side-left', 'active-side-right');
        });
        document.querySelectorAll('.aisle-part').forEach(x => x.classList.remove('active-part'));
        document.querySelectorAll('.highlighted-sec').forEach(span => {
            span.classList.remove('highlighted-sec');
            if (span.dataset.origText) span.innerText = span.dataset.origText;
        });
        document.querySelectorAll('.active-label').forEach(x => x.classList.remove('active-label'));
        
        const el = document.getElementById(`p-${id}`);
        let sideForLabel = 'L';
        let isRightClick = false;
        
        if (e && e.currentTarget) {
            const rect = e.currentTarget.getBoundingClientRect();
            // Solid, perfectly robust check ignoring any inner children
            isRightClick = e.clientX > (rect.left + (rect.width / 2));
        }
        
        let pathNum = id;
        let sideStr = 'Rechts';
        let secToHighlight = null;

        if (id !== '0AW' && id !== 'KAS' && id !== 'KOFFIE') {
            if (e && e.currentTarget && originalPart !== 'paint') {
                const rect = e.currentTarget.getBoundingClientRect();
                const clickY = e.clientY - rect.top;
                const ratio = 1 - Math.max(0, Math.min(1, clickY / rect.height)); 
                
                if (originalPart === 'top') {
                    secToHighlight = (7 + Math.floor(ratio * 10.99)).toString();
                } else if (originalPart === 'bottom') {
                    secToHighlight = (1 + Math.floor(ratio * 5.99)).toString();
                } else if (originalPart === 'full') {
                    secToHighlight = (1 + Math.floor(ratio * 16.99)).toString();
                }
            } else if (originalPart === 'paint') {
                secToHighlight = '1';
            } else {
                secToHighlight = '8'; 
            }
        } else if (id === '0AW') {
            if (e && e.target && e.target.tagName === 'SPAN' && e.target.dataset.sec) {
                // If they clicked exactly on the number span
                secToHighlight = e.target.dataset.sec;
            } else if (e && e.clientX !== undefined) {
                // Find the closest span mathematically if the map is compact (elements might be hidden)
                const wallEl = document.getElementById('p-0AW');
                if (wallEl) {
                    const spans = Array.from(wallEl.querySelectorAll('span[data-sec]'));
                    
                    if (spans.length > 0 && spans[0].getBoundingClientRect().width > 0) {
                        let closestSec = '9';
                        let minDistance = Infinity;

                        spans.forEach(sp => {
                            const spRect = sp.getBoundingClientRect();
                            const spCenterX = spRect.left + spRect.width / 2;
                            const spCenterY = spRect.top + spRect.height / 2;
                            
                            const dist = Math.sqrt(Math.pow(e.clientX - spCenterX, 2) + Math.pow(e.clientY - spCenterY, 2));
                            if (dist < minDistance) {
                                minDistance = dist;
                                closestSec = sp.dataset.sec;
                            }
                        });
                        secToHighlight = closestSec;
                    } else {
                        // Fallback mathematical ratio for compact map!
                        const rect = e.currentTarget.getBoundingClientRect();
                        const clickX = e.clientX - rect.left;
                        const ratio = Math.max(0, Math.min(1, clickX / rect.width));
                        secToHighlight = Math.max(1, Math.min(17, Math.round(ratio * 18))).toString();
                    }
                } else {
                    secToHighlight = '9';
                }
            } else {
                secToHighlight = '9'; // Default center
            }
        }

        if(el) {
            el.classList.add('active-num');
            
            if (id === '1L') {
                el.classList.add('active-side-right');
                sideForLabel = 'R'; 
                pathNum = '1L'; 
                sideStr = 'Rechts'; 
            } else if (id === '17') {
                el.classList.add('active-side-left');
                sideForLabel = 'L';
                pathNum = '17';
                sideStr = 'Links';
            } else {
                if (part === 'paint') {
                    el.classList.add('active-side-left');
                    sideForLabel = 'L';
                    pathNum = '9';
                    sideStr = 'Links';
                } else if (isRightClick) {
                    el.classList.add('active-side-right');
                    sideForLabel = 'R'; // Right face of the block
                    pathNum = id; // Walk down the pathway matching the block number
                    sideStr = 'Rechts'; // Look Right
                } else {
                    el.classList.add('active-side-left');
                    sideForLabel = 'L'; // Left face of the block
                    pathNum = id; // Walk down the pathway matching the block number
                    sideStr = 'Links'; // Look Left
                }
            }
            
            if (part === 'top') {
                el.classList.add('active-top');
                const pt = el.querySelector('.aisle-part.top');
                if(pt) pt.classList.add('active-part');
            } else if (part === 'bottom') {
                el.classList.add('active-bottom');
                const pt = el.querySelector('.aisle-part.bottom');
                if(pt) pt.classList.add('active-part');
            } else if (id == 9 && part === 'paint') {
                el.classList.add('active-bottom'); 
                const pt = el.querySelector('.aisle-part.bottom');
                if(pt) pt.classList.add('active-part');
                const lbl = document.getElementById('label-paint');
                if (lbl) lbl.classList.add('active-label');
            } else {
                el.classList.add('active'); // Catches 'full' triggers like Aisle 17 or unexpanded maps
                el.querySelectorAll('.aisle-part').forEach(p => p.classList.add('active-part'));
            }

            if (secToHighlight) {
                el.querySelectorAll('.sec-container span').forEach(span => {
                    if (!span.dataset.origText) span.dataset.origText = span.innerText;
                    if (span.dataset.origText === secToHighlight) {
                        span.classList.add('highlighted-sec');
                        span.innerText = span.dataset.origText + ' ' + sideForLabel; 
                    } else {
                        span.innerText = span.dataset.origText;
                    }
                });
            }
        } else if (id === '0AW' || id === 'KAS' || id === 'KOFFIE') {
            const specialEl = document.getElementById(id === '0AW' ? 'p-0AW' : (id === 'KAS' ? 'cashierZone' : 'coffeeCorner'));
            if(specialEl) specialEl.classList.add('active');

            if (id === '0AW') {
                specialEl.querySelectorAll('.sec-container span').forEach(span => {
                    if (!span.dataset.origText) span.dataset.origText = span.innerText;
                    if (span.dataset.origText === '9' || span.dataset.sec === secToHighlight) {
                        span.classList.add('highlighted-sec');
                    } else {
                        span.innerText = span.dataset.origText;
                    }
                });
            }

            if (id === 'KAS') {
                const lbl = document.getElementById('label-' + (part || 'kassa'));
                if (lbl) lbl.classList.add('active-label');
            } else if (id === 'KOFFIE') {
                const lbl = document.getElementById('label-coffee');
                if (lbl) lbl.classList.add('active-label');
            }
        }
        
        window.activeMapTarget = { pad: pathNum, sec: secToHighlight, side: sideStr, subTarget: part };
        
        // Single click just moves char. Double click handles expansion.
        moveChar(pathNum, true, pathNum !== 'KAS' && pathNum !== 'KOFFIE', secToHighlight, sideStr);
    }

    function toggleMapExpand(expand) {
        const wrapper = document.getElementById('mapWrapper');
        const path = document.getElementById('guideLine');
        if (!wrapper) return;
        
        if (path) path.setAttribute('d', ''); // Clear path before animating
        
        if (expand) {
            wrapper.classList.add('map-expanded-overlay');
        } else {
            wrapper.classList.remove('map-expanded-overlay');
        }
        
        setTimeout(() => {
            if (window.activeMapTarget) {
                moveChar(window.activeMapTarget.pad, true, true, window.activeMapTarget.sec, window.activeMapTarget.side);
            } else {
                moveChar('entrance', false, false, null, null);
            }
        }, 450); 
    }

    function clearSearch() {
        closeSelection(); 
        const searchBox = document.getElementById('searchBox');
        const ghost = document.getElementById('searchGhost');
        if(searchBox) {
            searchBox.value = '';
            searchBox.focus(); 
        }
        if (ghost) {
            ghost.innerHTML = '';
            ghost.dataset.suggestion = '';
        }
        currentCategory = 'all'; 
        renderCategoryChips();
        handleSearch(); 
    }

    function handleSearch() {
        const input = document.getElementById('searchBox');
        if (!input) return; 
        const val = input.value; 
        const trimVal = val.trim();
        const app = document.getElementById('mainApp');
        const ghost = document.getElementById('searchGhost');
        const clearBtn = document.getElementById('clearBtn');
        if(clearBtn) clearBtn.style.display = (trimVal || currentCategory !== 'all') ? 'flex' : 'none';
        
        // --- 1. Autocomplete / Suggestion Logic ---
        if (val && val === val.trimStart()) {
            const tokens = val.toLowerCase().split(/\s+/);
            const lastToken = tokens[tokens.length - 1];
            const normLast = lastToken.replace(/[^a-z0-9]/g, '');
            
            if (normLast.length >= 1) { // Nu suggesties vanaf de allereerste letter
                const match = window.dictArray.find(w => w.startsWith(normLast));
                if (match) {
                    const suggestionSuffix = match.substring(normLast.length);
                    const safeVal = val.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    ghost.innerHTML = `<span style="visibility:hidden;">${safeVal}</span>${suggestionSuffix}`;
                    ghost.dataset.suggestion = val + suggestionSuffix;
                } else {
                    ghost.innerHTML = ""; ghost.dataset.suggestion = "";
                }
            } else {
                ghost.innerHTML = ""; ghost.dataset.suggestion = "";
            }
        } else {
            ghost.innerHTML = ""; ghost.dataset.suggestion = "";
        }

        if(!trimVal && currentCategory === 'all') { 
            if(ghost) ghost.innerHTML = "";
            if(app) app.classList.remove('searching'); return; 
        }
        if(app) app.classList.add('searching');
        executeHeavySearch(trimVal, normalizeStr(trimVal), document.getElementById('resultCount'), currentCategory);
    }

    function executeHeavySearch(originalVal, normVal, counter, catFilter) {
        const t = i18n[curLang] || i18n['nl']; 
        const list = document.getElementById('resultsList');
        if (!list) return;
        
        const tokens = normVal.split(/\s+/).filter(w => w.length > 0);
        let results = data.filter(item => {
            if (catFilter !== 'all' && item["Hoofdgroep"] !== catFilter) return false;
            return tokens.every(tok => item._searchStr.includes(tok));
        });
        
        // --- 2. Typo Tolerance / Fuzzy Search Fallback ---
        if (results.length === 0 && tokens.length > 0) {
            results = data.filter(item => {
                if (catFilter !== 'all' && item["Hoofdgroep"] !== catFilter) return false;
                return tokens.every(tok => {
                    if (item._searchStr.includes(tok)) return true;
                    if (tok.length <= 2) return false; 
                    return item._nameWords.some(w => {
                        if (w.length <= 2 || Math.abs(w.length - tok.length) > 2) return false;
                        return levenshteinDistance(tok, w) <= 1; 
                    });
                });
            });
        }
        
        if (counter) {
            counter.innerText = `${results.length} ${results.length === 1 ? t.resFoundSingular : t.resFoundPlural}`;
        }
        
        if (results.length === 0) {
            list.innerHTML = `<div style="text-align:center; padding: 40px; font-weight: bold; color: var(--text-muted);">${t.noResTitle} "${originalVal.replace(/</g, "&lt;")}"</div>`;
            return;
        }

        // --- 3. Advanced Highlighting Logic ---
        const rawTokens = originalVal.split(/\s+/).filter(w => w.length > 0);
        const highlightText = (text) => {
            if (!text) return '';
            let str = String(text);
            if (rawTokens.length === 0) return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
            
            const validTokens = rawTokens.filter(t => t.trim().length > 0).sort((a,b) => b.length - a.length);
            if (validTokens.length === 0) return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

            const escapedTokens = validTokens.map(t => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
            const regex = new RegExp(`(${escapedTokens.join('|')})`, 'gi');
            
            // Veilige markering die HTML entiteiten niet breekt
            str = str.replace(regex, '\u0001$1\u0002');
            str = str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
            str = str.replace(/\u0001/g, '<mark>').replace(/\u0002/g, '</mark>');
            return str;
        };

        list.innerHTML = results.map(item => {
            const loc2 = item.Locatie2 || '';
            const loc2Up = loc2.toUpperCase();
            
            // Robust parsing for special pads or normal pads
            let pad = '0AW';
            let padDisplay = '0AW';
            let subTarget = '';
            
            if (loc2Up.includes('PAD KA') || loc2Up.includes('KAS')) { 
                pad = 'KAS'; padDisplay = 'KAS'; 
                if (loc2Up.includes('SERVICE')) subTarget = 'service';
                else if (loc2Up.includes('VERKOOP') || (item["Artikel omsch."] && item["Artikel omsch."].toUpperCase().includes('KEUKEN'))) subTarget = 'sales1';
                else subTarget = 'kassa';
            }
            else if (loc2Up.includes('PAD VM') || loc2Up.includes('VMB')) { pad = '9'; padDisplay = 'VMB'; subTarget = 'paint'; }
            else if (loc2Up.includes('PAD LI') || loc2Up.includes('LIJ')) { pad = '2'; padDisplay = 'LIJ'; }
            else if (loc2Up.includes('PAD BA') || loc2Up.includes('BAL')) { pad = 'KAS'; padDisplay = 'BAL'; subTarget = 'service'; }
            else if (loc2Up.includes('PAD PB') || loc2Up.includes('PBM')) { pad = '13'; padDisplay = 'PBM'; }
            else if (loc2Up.includes('KOFFIE')) { pad = 'KOFFIE'; padDisplay = 'KOF'; subTarget = 'coffee'; }
            else if (loc2Up.includes('0A') || loc2Up.includes('AW')) { pad = '0AW'; padDisplay = '0AW'; }
            else {
                const padMatch = loc2.match(/Pad\s*0*(\d+)/i);
                if (padMatch) {
                    pad = parseInt(padMatch[1], 10).toString();
                    padDisplay = pad;
                } else {
                    const fallbackMatch = loc2.match(/0*(\d+)/);
                    if (fallbackMatch) {
                        const num = parseInt(fallbackMatch[1], 10);
                        if (num > 0 && num <= 17) {
                            pad = num.toString();
                            padDisplay = pad;
                        }
                    }
                }
            }

            const secMatch = loc2.match(/Sectie\s+(\d+)/i);
            const sec = secMatch ? parseInt(secMatch[1], 10).toString() : '1';
            const sideRaw = loc2.includes('Rechts') ? 'Rechts' : 'Links';
            const sideTrans = sideRaw === 'Rechts' ? t.right : t.left;
            
            let isSpecial = isNaN(parseInt(pad, 10)) || pad === '0AW' || padDisplay === 'VMB' || padDisplay === 'LIJ' || padDisplay === 'BAL' || padDisplay === 'PBM';

            let badgeHtml = '';
            if (isSpecial) {
                badgeHtml = `
                <div class="badge" style="background: var(--primary-dark);">
                    <span>LOC</span>
                    <b style="font-size: 1.1rem;">${padDisplay}</b>
                </div>`;
            } else {
                badgeHtml = `
                <div class="badge">
                    <span>${t.pad}</span>
                    <b>${padDisplay}</b>
                    <div class="sectie-label-badge">${sideTrans}<br>${t.sect} ${sec}</div>
                </div>`;
            }

            const catIcon = icons[item["Hoofdgroep"]] || '📦';
            const tUnknownLoc = t.unknownLoc || "Onbekende locatie";
            
            // Toepassen van Highlighting op de weergave
            const safeArtNrHighlight = highlightText(item["ArtikelNr."]);
            const safeOmschHighlight = highlightText(item["Artikel omsch."]);
            const hgHighlight = highlightText(item["Hoofdgroep"]);
            const sgHighlight = highlightText(item["Subgroep"]);
            
            // Raw properties voor code-executie in onclick
            const safeArtNr = String(item["ArtikelNr."] || '').replace(/\\/g, "\\\\").replace(/'/g, "\\'");

            const artFileName = encodeURIComponent(String(item["ArtikelNr."] || ''));
            // Image targeting .webp directly, with smart fallback to Emoji Icon
            const imgHtml = `<img src="./img/${artFileName}.webp" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" alt="${safeOmschHighlight}">` + 
                            `<div class="fallback-icon" style="display:none;">${catIcon}</div>`;
            
            return `<div class="result-item" onclick="selectItem('${pad}', '${sec}', '${sideRaw}', this, '${subTarget}', '${safeArtNr}')">
                <div class="icon-wrap">${imgHtml}</div>
                <div class="info">
                    <h3>${safeOmschHighlight}</h3>
                    <div style="font-size: 0.75rem; color: var(--text-muted); font-weight: 800; margin-bottom: 4px;">Art. ${safeArtNrHighlight}</div>
                    <div class="tags">
                        <span class="tag">${hgHighlight}</span>
                        <span class="tag sub">${sgHighlight}</span>
                    </div>
                </div>
                ${badgeHtml}
            </div>`;
        }).join('');
    }

    let currentSelectedProduct = null;

    function getMapTarget(pad, side) {
        let targetPad = pad;
        let isRightOfRack = false; 
        
        if (!isNaN(pad)) {
            if (side && side.toLowerCase().includes('link')) {
                targetPad = (parseInt(pad) - 1).toString();
                if (targetPad === '0') targetPad = '1L';
                isRightOfRack = true; 
            } else {
                targetPad = pad.toString();
                isRightOfRack = false; 
            }
        } else if (pad === '1L') {
            targetPad = '1L';
            isRightOfRack = true;
        }
        return { targetPad, isRightOfRack };
    }

    function selectItem(pad, sec, side, el, subTarget = '', artNr = null) {
        document.querySelectorAll('.aisle, .back-wall, .result-item, .paint-table').forEach(x => {
            x.classList.remove('active', 'active-top', 'active-bottom', 'active-num', 'selected', 'active-side-left', 'active-side-right');
        });
        document.querySelectorAll('.aisle-part').forEach(x => x.classList.remove('active-part'));
        document.querySelectorAll('.highlighted-sec').forEach(span => {
            span.classList.remove('highlighted-sec');
            if (span.dataset.origText) span.innerText = span.dataset.origText;
        });
        document.querySelectorAll('.active-label').forEach(x => x.classList.remove('active-label'));
        if (el) el.classList.add('selected');
        
        const card = document.getElementById('productDetailCard');
        const t = i18n[curLang] || i18n['nl'];
        const tUnknownLoc = t.unknownLoc || "Onbekende locatie";
        if (card) {
            if (artNr) {
                currentSelectedProduct = { pad, sec, side, el, subTarget, artNr };
                const item = data.find(d => String(d["ArtikelNr."]) === String(artNr));
                if (item) {
                    const catIcon = icons[item["Hoofdgroep"]] || '📦';
                    
                    // Robust string escaping to prevent JS syntax errors from items with quotes like 3/8''
                    const nameStr = item["Artikel omsch."] || '';
                    const htmlSafeName = nameStr.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
                    const jsSafeName = nameStr.replace(/\\/g, "\\\\").replace(/'/g, "\\'").replace(/"/g, "&quot;");
                    
                    const locStr = item["Locatie2"] || item["Schaplocatie code"] || '';
                    const jsSafeLoc = locStr.replace(/\\/g, "\\\\").replace(/'/g, "\\'").replace(/"/g, "&quot;");
                    const displayLoc = item["Locatie2"] || item["Schaplocatie code"] || tUnknownLoc;
                    
                    const artFileName = encodeURIComponent(String(item["ArtikelNr."] || ''));
                    // Image with .webp fallback for the Product Detail Card
                    const pdImgHtml = `<img src="./img/${artFileName}.webp" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" style="width: 100%; height: 100%; object-fit: contain; padding: 3px; box-sizing: border-box;" alt="${htmlSafeName}">` + 
                                      `<div style="display:none; width:100%; height:100%; align-items:center; justify-content:center; font-size: 1.3rem;">${catIcon}</div>`;

                    card.innerHTML = `
                        <div class="pd-header">
                            <div class="pd-icon">${pdImgHtml}</div>
                            <div class="pd-info">
                                <h3 class="pd-title" title="${htmlSafeName}">${htmlSafeName}</h3>
                                <div class="pd-art">Art. ${item["ArtikelNr."]}</div>
                            </div>
                        </div>
                        <div class="pd-bottom-row">
                            <div class="pd-loc-banner">
                                📍 ${displayLoc}
                            </div>
                            <button class="pd-print-btn" title="${t.printBtn.replace('🖨️ ', '')}" onclick="event.stopPropagation(); printTicket('${jsSafeName}', '${item["ArtikelNr."]}', '${jsSafeLoc}')">
                                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
                            </button>
                        </div>
                    `;
                    card.onclick = () => {
                        // Fully re-select the item to restore the specific section highlight
                        selectItem(pad, sec, side, el, subTarget, artNr);
                    };
                    card.classList.add('show');
                }
            } else if (!currentSelectedProduct) {
                card.classList.remove('show');
            }
        }

        const { targetPad, isRightOfRack } = getMapTarget(pad, side);
        const padEl = document.getElementById(`p-${targetPad}`);
        
        if (padEl) {
            padEl.classList.add('active-num');
            if (isRightOfRack) {
                padEl.classList.add('active-side-right');
            } else {
                padEl.classList.add('active-side-left');
            }
            
            if (targetPad === '1L' || targetPad === '17') {
                padEl.classList.add('active');
                padEl.querySelectorAll('.aisle-part').forEach(p => p.classList.add('active-part'));
            } else {
                const isTop = parseInt(sec) > 6;
                padEl.classList.add(isTop ? 'active-top' : 'active-bottom');
                const targetPart = padEl.querySelector(isTop ? '.aisle-part.top' : '.aisle-part.bottom');
                if (targetPart) targetPart.classList.add('active-part');
            }
            if (sec) {
                padEl.querySelectorAll('.sec-container span').forEach(span => {
                    if (!span.dataset.origText) span.dataset.origText = span.innerText;
                    if (span.dataset.origText === sec.toString()) {
                        span.classList.add('highlighted-sec');
                        const sideChar = (side && side.toLowerCase().includes('recht')) ? 'R' : 'L';
                        span.innerText = span.dataset.origText + ' ' + sideChar;
                    } else {
                        span.innerText = span.dataset.origText;
                    }
                });
            }
        } else if (pad === '0AW') {
            const backWall = document.getElementById('p-0AW');
            if (backWall) {
                backWall.classList.add('active');
                if (sec) {
                    backWall.querySelectorAll('.sec-container span').forEach(span => {
                        if (!span.dataset.origText) span.dataset.origText = span.innerText;
                        if (span.dataset.sec === sec.toString() || span.dataset.origText === sec.toString()) {
                            span.classList.add('highlighted-sec');
                        } else {
                            span.innerText = span.dataset.origText;
                        }
                    });
                }
            }
        } else if (pad === 'KAS') {
            const cashierEl = document.getElementById('cashierZone');
            if(cashierEl) cashierEl.classList.add('active');
            if (subTarget) {
                const lbl = document.getElementById('label-' + subTarget);
                if (lbl) lbl.classList.add('active-label');
            } else {
                const lbl = document.getElementById('label-kassa');
                if (lbl) lbl.classList.add('active-label');
            }
        } else if (pad === 'KOFFIE') {
            const cofEl = document.getElementById('coffeeCorner');
            if(cofEl) cofEl.classList.add('active');
            const lbl = document.getElementById('label-coffee');
            if (lbl) lbl.classList.add('active-label');
        }

        if (pad === '9' && subTarget === 'paint') {
            const lbl = document.getElementById('label-paint');
            if (lbl) lbl.classList.add('active-label');
        }

        let pathNum = pad;
        window.activeMapTarget = { pad: pathNum, sec, side, subTarget };
        
        // Auto-expand the map as an overlay when a product is selected from search results
        const wrapper = document.getElementById('mapWrapper');
        if (!wrapper.classList.contains('map-expanded-overlay')) {
            toggleMapExpand(true);
        } else {
            moveChar(pathNum, true, true, sec, side);
        }
    }

    function closeSelection() {
        document.querySelectorAll('.aisle, .back-wall, .result-item, .paint-table').forEach(x => {
            x.classList.remove('active', 'active-top', 'active-bottom', 'active-num', 'selected', 'active-side-left', 'active-side-right');
        });
        document.querySelectorAll('.aisle-part').forEach(x => x.classList.remove('active-part'));
        document.querySelectorAll('.highlighted-sec').forEach(span => {
            span.classList.remove('highlighted-sec');
            if (span.dataset.origText) span.innerText = span.dataset.origText;
        });
        document.querySelectorAll('.active-label').forEach(x => x.classList.remove('active-label'));
        
        const card = document.getElementById('productDetailCard');
        if (card) {
            card.classList.remove('show');
        }

        const floor = document.getElementById('mapGrid');
        if (floor) floor.classList.remove('zoomed');
        window.isZoomed = false;
        
        currentSelectedProduct = null;
        window.activeMapTarget = null;
        moveChar('entrance', false, false, null, null);
    }

    function moveChar(pad, active, line, sec, side) {
        const char = document.getElementById('mainChar'), path = document.getElementById('guideLine');
        const grid = document.getElementById('mapGrid');
        if (!char || !path || !grid) return; 

        const sPos = window.entrancePosX || 270;
        let cPos = sPos, targetBottom = '0%'; 

        let aisleTarget = 75; 
        
        if (pad === 'KAS') { 
            const kasEl = document.getElementById('cashierZone');
            let targetDesk = kasEl;
            const sub = window.activeMapTarget ? window.activeMapTarget.subTarget : null;
            if (sub === 'service') targetDesk = document.getElementById('desk-service');
            else if (sub === 'sales1') targetDesk = document.getElementById('desk-sales1');
            else if (sub === 'kassa') targetDesk = document.getElementById('desk-kassa');

            if (targetDesk && targetDesk.id !== 'cashierZone') {
                cPos = kasEl.offsetLeft + targetDesk.offsetLeft + (targetDesk.offsetWidth / 2);
            } else if (kasEl) {
                cPos = kasEl.offsetLeft + (kasEl.offsetWidth / 2);
            } else {
                cPos = 400;
            }
            
            // Stand cleanly in the pathway (9% depth) in front of the desk instead of inside it
            aisleTarget = 9;
            targetBottom = active ? `${aisleTarget}%` : `0%`; 
        }
        else if (pad === 'KOFFIE') {
            const cofEl = document.getElementById('coffeeCorner');
            cPos = cofEl ? cofEl.offsetLeft + 20 : 800;
            targetBottom = '8%';
        }
        else if (pad === '0AW') { 
            cPos = sPos; 
            targetBottom = active ? '83%' : '0%'; // Keep character well away from the edge so it stands visible IN FRONT of the wall
            // finalX calculation for 0AW happens in the finalX block below to allow for central aisle navigation
        }
        else if (pad !== 'entrance') {
            const { targetPad, isRightOfRack } = getMapTarget(pad, side);

            const t = document.getElementById(`p-${targetPad}`);
            if(t) {
                if (sec && !isNaN(sec)) {
                    // Try DOM calculation first
                    const padElForSec = document.getElementById(`p-${targetPad}`);
                    let targetSpan = null;
                    if (padElForSec) {
                        const spans = padElForSec.querySelectorAll('.sec-container span');
                        spans.forEach(sp => {
                            if (sp.dataset.origText === sec.toString()) {
                                targetSpan = sp;
                            }
                        });
                    }
                    if (targetSpan && targetSpan.offsetHeight > 0) {
                        let el = targetSpan;
                        let topOffset = 0;
                        while(el && el.id !== 'mapGrid' && el.tagName !== 'BODY') {
                            topOffset += el.offsetTop;
                            el = el.offsetParent;
                        }
                        aisleTarget = 100 - ((topOffset + (targetSpan.offsetHeight / 2)) / grid.offsetHeight * 100);
                    } else {
                        // Math Fallback (bulletproof against display: none)
                        const s = parseInt(sec);
                        if (targetPad === '1' || targetPad === '17' || targetPad === '1L') {
                            aisleTarget = 15 + ((s - 1) / 16) * 70;
                        } else {
                            if (s <= 6) { aisleTarget = 15 + ((s - 1) / 5) * 20; } 
                            else { aisleTarget = 48 + ((s - 7) / 10) * 37; }
                        }
                    }
                }

                // Path centering logic: If Right, walk to the right of the current aisle. If Left, walk to the left.
                if (isRightOfRack) {
                    let nextPadNum = targetPad === '1L' ? '1' : (parseInt(targetPad) + 1).toString();
                    const nextT = document.getElementById(`p-${nextPadNum}`);
                    if (nextT) {
                        cPos = t.offsetLeft + t.offsetWidth + ((nextT.offsetLeft - (t.offsetLeft + t.offsetWidth)) / 2);
                    } else {
                        cPos = t.offsetLeft + t.offsetWidth + 12;
                    }
                } else {
                    let prevPadNum = targetPad === '1' ? '1L' : (parseInt(targetPad) - 1).toString();
                    const prevT = document.getElementById(`p-${prevPadNum}`);
                    if (prevT) {
                        cPos = prevT.offsetLeft + prevT.offsetWidth + ((t.offsetLeft - (prevT.offsetLeft + prevT.offsetWidth)) / 2);
                    } else {
                        cPos = t.offsetLeft - 12;
                    }
                }
                targetBottom = active ? `${aisleTarget}%` : `0%`;
            }
        }

        // --- FINAL X DETERMINATION (For stepping to shelves or navigating backwall) ---
        let finalX_0AW = sPos; 
        if (active && pad === '0AW') {
            if (sec && !isNaN(sec)) {
                // Math fallback is flawless and avoids display:none bugs when map is unexpanded
                const s = parseInt(sec);
                // Grid has padding 10px on sec-container, and 17 spans distributed space-evenly (18 gaps)
                finalX_0AW = 10 + (grid.offsetWidth - 20) * (s / 18);
            } else {
                finalX_0AW = grid.offsetWidth / 2;
            }
        }

        let finalX = cPos;
        if (active && pad === '0AW') {
            finalX = finalX_0AW; // Backwall lateral movement
        } else if (active && pad !== 'entrance' && pad !== 'KAS' && pad !== 'KOFFIE') {
            const { targetPad, isRightOfRack } = getMapTarget(pad, side);
            const targetRack = document.getElementById(`p-${targetPad}`);
            
            if (targetRack) {
                 if (isRightOfRack) {
                     finalX = targetRack.offsetLeft + targetRack.offsetWidth + 8; // Step left towards the right face of the rack
                 } else {
                     finalX = targetRack.offsetLeft - 8; // Step right towards the left face of the rack
                 }
            }
        }

        if (window.charMoveTimeouts) window.charMoveTimeouts.forEach(clearTimeout);
        window.charMoveTimeouts = [];

        char.style.transition = 'none';
        char.style.left = `${sPos}px`;
        char.style.bottom = '0%';
        char.classList.remove('running');
        document.documentElement.style.setProperty('--char-dir', '1');

        char.getBoundingClientRect();

        if (!active || pad === 'entrance') {
            path.setAttribute('d', '');
            path.style.animation = 'none';
            return;
        }

        const floorHeight = grid.offsetHeight;
        const startY = floorHeight;
        const midY = floorHeight - (8 / 100 * floorHeight); 
        const targetBVal = parseFloat(targetBottom);
        const endY = floorHeight - (targetBVal / 100 * floorHeight);

        const d1 = startY - midY; 
        const d2 = Math.abs(cPos - sPos);
        const d3 = Math.abs(midY - endY); 
        const d4 = Math.abs(finalX - cPos);
        const totalDist = d1 + d2 + d3 + d4 || 1;
        const totalTime = 1600; 
        const t1 = (d1 / totalDist) * totalTime;
        const t2 = (d2 / totalDist) * totalTime;
        const t3 = (d3 / totalDist) * totalTime;
        const t4 = (d4 / totalDist) * totalTime;

        const pathStr = `M ${sPos},${startY} L ${sPos},${midY} L ${cPos},${midY} L ${cPos},${endY} L ${finalX},${endY}`;
        const newPath = path.cloneNode(true);
        newPath.setAttribute('d', pathStr);
        newPath.style.strokeDasharray = totalDist;
        newPath.style.strokeDashoffset = totalDist;
        newPath.style.animation = 'none';
        path.parentNode.replaceChild(newPath, path);
        
        newPath.getBoundingClientRect();
        newPath.style.animation = `drawPath 1.6s linear forwards`;

        char.classList.add('running');
        
        char.style.transition = `bottom ${t1}ms linear`;
        char.style.bottom = '8%';

        window.charMoveTimeouts.push(setTimeout(() => {
            document.documentElement.style.setProperty('--char-dir', cPos < sPos ? '-1' : '1');
            char.style.transition = `left ${t2}ms linear`;
            char.style.left = `${cPos}px`;
        }, t1));

        window.charMoveTimeouts.push(setTimeout(() => {
            // Walk straight up the aisle facing forward
            document.documentElement.style.setProperty('--char-dir', '1');
            char.style.transition = `bottom ${t3}ms linear`;
            char.style.bottom = targetBottom;
        }, t1 + t2));

        window.charMoveTimeouts.push(setTimeout(() => {
            if (active && pad === '0AW') {
                 // For backwall, it walks horizontally here
                 document.documentElement.style.setProperty('--char-dir', finalX < cPos ? '-1' : '1');
                 char.style.transition = `left ${t4}ms linear`;
                 char.style.left = `${finalX}px`;
            } else if (active && pad !== 'entrance' && pad !== 'KAS' && pad !== 'KOFFIE' && pad !== '0AW') {
                 // Character turning logic based on walking path
                 const turnDir = (side && side.toLowerCase().includes('link')) ? '-1' : '1';
                 document.documentElement.style.setProperty('--char-dir', turnDir);
                 
                 char.style.transition = `left ${t4}ms linear`;
                 char.style.left = `${finalX}px`;
            } else {
                 document.documentElement.style.setProperty('--char-dir', '1');
            }
        }, t1 + t2 + t3));

        window.charMoveTimeouts.push(setTimeout(() => {
            char.classList.remove('running');
            if (active && pad === '0AW') {
                // Ensure the character faces the wall at the very end
                document.documentElement.style.setProperty('--char-dir', '1');
            }
        }, totalTime));
    }

    function handleKeys(e) { 
        if (e.key === "Escape") clearSearch(); 
        if (e.key === "Tab" || e.key === "ArrowRight") {
            const ghost = document.getElementById('searchGhost');
            if (ghost && ghost.dataset.suggestion) {
                e.preventDefault();
                const searchBox = document.getElementById('searchBox');
                searchBox.value = ghost.dataset.suggestion;
                handleSearch();
            }
        }
    }
    
    function closeImageModal() {}

    function printTicket(name, art, loc) {
        const printArea = document.getElementById('printArea');
        if(printArea) {
            printArea.innerHTML = `
                <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 10px; color: #005cb9;">BOUWMAAT AMSTEL XL</div>
                <hr style="border: 2px solid #005cb9; margin-bottom: 20px;">
                <div style="font-size: 1.2rem; font-weight: 900; margin-bottom: 10px;">${name}</div>
                <div style="font-size: 1rem; color: #475569; font-weight: 800; margin-bottom: 20px;">Art: ${art}</div>
                <div style="font-size: 1rem; font-weight: 800; text-transform: uppercase;">LOCATIE:</div>
                <h1 style="font-size: 3.5rem; color: #005cb9; margin: 10px 0;">${loc}</h1>
            `;
        }
        window.print();
    }
</script>
</body>
</html>
